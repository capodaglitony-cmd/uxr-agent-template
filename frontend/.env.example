# Copy to .env.local for local dev; set in Vercel project env vars for deploy.

# ── Modal backend ────────────────────────────────────────────────────────

# Modal endpoint that hosts the FastAPI backend. Set after `modal deploy
# backend/modal_app.py` — Modal prints the URL on success.
MODAL_ENDPOINT=https://your-handle--uxr-agent-template-fastapi-app.modal.run

# Same X-Admin-Token value you registered as the `admin-token` Modal secret.
# The /api/admin/ingest server-side route uses this to authenticate to
# Modal's /admin/ingest. Browser never sees this value.
ADMIN_TOKEN=

# ── Auth.js GitHub OAuth ─────────────────────────────────────────────────

# GitHub handle allowed to access /admin. The Auth.js signIn callback
# rejects any other handle before a session is created.
OWNER_GITHUB_USER=your-github-handle

# Required by Auth.js v5 to sign session JWTs. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# or
#   openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App credentials. Create one at
# https://github.com/settings/developers (or your org's developer settings).
# Authorization callback URL when creating the OAuth App:
#   https://<your-vercel-deployment>.vercel.app/api/auth/callback/github
# For local dev, also add http://localhost:3000/api/auth/callback/github.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
